# ==========================================
# CyberInsight Backend Environment Variables
# ==========================================

# ------------------------------------------
# Application
# ------------------------------------------
APP_NAME=CyberInsight API
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True

# ------------------------------------------
# Security
# ------------------------------------------
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------
# Database
# ------------------------------------------
DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/cyberinsight

# ------------------------------------------
# CORS
# ------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081